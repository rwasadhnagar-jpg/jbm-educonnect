# ============================================================
# JBM EduConnect — Environment Variables Template
# Copy this file to server/.env and fill in all values.
# NEVER commit the actual .env file to git.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_minimum_64_chars_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_minimum_64_chars_here

# ── Supabase ─────────────────────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── Google Meet (Video Sessions) ─────────────────────────────
# Requires Google Workspace + Google Meet API enabled in Google Cloud Console
#
# Setup:
# 1. console.cloud.google.com → Enable "Google Meet API"
# 2. IAM → Service Accounts → Create → Download JSON key
# 3. Workspace Admin → Security → API Controls → Domain-wide Delegation
#    Add client_id from the JSON, scope: https://www.googleapis.com/auth/meetings.space.created
#
# Paste the entire service account JSON as a single line:
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","client_email":"...","private_key":"..."}
# A Workspace admin/teacher email used for read-only Meet API lookups:
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@yourschool.edu

# ── Firebase (Push Notifications) ────────────────────────────
# Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON as a single line
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Resend (Parent Email Alerts) ─────────────────────────────
# Sign up free at: https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=JBM EduConnect <noreply@yourdomain.com>

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://jbm-educonnect.vercel.app,http://localhost:5173

# ── Frontend (Vite — prefix with VITE_ to expose to browser) ─
VITE_API_URL=https://your-backend.railway.app
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_VAPID_KEY=your_vapid_key_for_web_push
